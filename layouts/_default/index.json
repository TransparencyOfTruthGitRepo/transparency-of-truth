{{- $items := slice -}}

{{- /* Index all content pages */ -}}
{{- range .Site.RegularPages -}}
  {{- $items = $items | append (dict
    "type" "page"
    "title" .Title
    "url" .RelPermalink
    "summary" (.Params.summary | default (.Summary | plainify | truncate 150))
  ) -}}
{{- end -}}

{{- /* Index all officials from data */ -}}
{{- range (where .Site.RegularPages "Type" "states") -}}
  {{- $slug := .File.ContentBaseName -}}
  {{- $stateTitle := .Title -}}
  {{- $stateURL := .RelPermalink -}}
  {{- $data := index hugo.Data.officials $slug -}}
  {{- if and $data $data.officials -}}
    {{- range $data.officials -}}
      {{- $items = $items | append (dict
        "type" "official"
        "title" .full_name
        "url" $stateURL
        "summary" (printf "%s · %s · %s" .office_title $stateTitle .party)
        "party" .party
        "office" .office_title
        "state" $stateTitle
      ) -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- $items | jsonify -}}